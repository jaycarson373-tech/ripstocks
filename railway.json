{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "node -e \"console.log('Dependencies installed; Next build runs at boot')\""
  },
  "deploy": {
    "startCommand": "npm run railway-boot",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
